# Copy to .env and fill values (never commit real keys)

# --- Wallet / signing (required for trading) ---
# Base58 private key OR uint8 array string.
PRIVATE_KEY=

# --- Jupiter ---
# Optional: enables https://api.jup.ag (keyed) instead of default lite endpoint.
JUPITER_API_KEY=

# Quote endpoint base. Defaults to Jupiter Lite (no key required).
JUP_QUOTE_BASE=https://lite-api.jup.ag

# --- Bot per-coin config ---
TICKER=
TOKEN_MINT=

# Buy size in lamports (default 0.04 SOL)
AMOUNT_LAMPORTS=40000000

# Max simultaneously open grid slots
MAX_POSITIONS=20
